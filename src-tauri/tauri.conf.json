{
  "build": {
    "beforeBuildCommand": "npm run build:web",
    "beforeDevCommand": "npm run dev:web",
    "devPath": "http://localhost:5177",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Enderfall Calander",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "fs": {
        "readFile": true,
        "writeFile": true,
        "createDir": true,
        "scope": ["$APPDATA/Enderfall/**", "$LOCALDATA/Enderfall/**"]
      },
      "shell": {
        "open": true
      },
      "path": {
        "all": true
      }
    },
    "windows": [
      {
        "title": "Enderfall Calander",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "identifier": "com.enderfall.calander",
      "targets": "all",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/256x256.png",
        "icons/256x256@2x.png",
        "icons/512x512.png",
        "icons/icon.ico"
      ]
    }
  }
}
